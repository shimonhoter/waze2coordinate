<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f0f4f8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layoutDirection="rtl">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#ffffff">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2c3e50"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/sourceToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSourceWaze"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/source_waze"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSourceMaps"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/source_maps"
                        app:cornerRadius="8dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickOnMap"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/btn_pick_on_map"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_map"
                    app:iconGravity="textStart" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editUrlLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_url"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textDirection="ltr"
                        android:gravity="start" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConvert"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/btn_convert"
                    android:textSize="16sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#3498db" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="12dp"
                    android:background="#fde8e8"
                    android:textColor="#e74c3c"
                    android:textStyle="bold"
                    android:textIsSelectable="true"
                    android:textDirection="ltr"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/resultLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:padding="16dp"
                    android:background="#f8fafc"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_lat"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/latValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textDirection="ltr"
                            android:fontFamily="monospace"
                            android:textColor="#2c3e50"
                            android:background="#e2e8f0"
                            android:padding="6dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_lon"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/lonValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textDirection="ltr"
                            android:fontFamily="monospace"
                            android:textColor="#2c3e50"
                            android:background="#e2e8f0"
                            android:padding="6dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopy"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/btn_copy"
                        app:cornerRadius="8dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenMaps"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_open_maps"
                        app:cornerRadius="8dp"
                        app:backgroundTint="#27ae60" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNavigateWaze"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_navigate_waze"
                        app:cornerRadius="8dp"
                        app:backgroundTint="#33ccff" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="@string/hint_description"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSendSms"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/btn_send_sms"
                            android:textSize="13sp"
                            app:cornerRadius="8dp"
                            app:icon="@drawable/ic_sms"
                            app:iconGravity="textStart"
                            app:backgroundTint="#607d8b" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSendWhatsapp"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/btn_send_whatsapp"
                            android:textSize="13sp"
                            app:cornerRadius="8dp"
                            app:icon="@drawable/ic_whatsapp"
                            app:iconGravity="textStart"
                            app:backgroundTint="#25D366" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    </ScrollView>

    <!-- מסך מפה במסך מלא - מכוסה על כל המסך כשהוא פעיל (visibility=gone כברירת מחדל).
         כל ממשק המשתמש (סרגל כלים, חיפוש כתובת, כפתורי GPS, רמזים) מצויר בתוך ה-HTML/JS
         עצמו (map.html) ולא ב-native, כדי לתמוך בעיצוב המודרני המבוסס Leaflet.Draw. -->
    <FrameLayout
        android:id="@+id/mapFullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#ffffff"
        android:visibility="gone">

        <WebView
            android:id="@+id/mapWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

</FrameLayout>
