<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootFrame"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layoutDirection="rtl">

        <!-- כותרת + טוגל מצב כהה/בהיר -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_primary"
                android:letterSpacing="-0.01" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleTheme"
                style="?attr/materialIconButtonStyle"
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:icon="@drawable/ic_theme_toggle"
                app:iconSize="20dp"
                app:iconTint="@color/app_text_secondary" />

        </LinearLayout>

        <!-- כרטיס ההמרה הראשי -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/app_border"
            app:cardBackgroundColor="@color/app_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/sourceToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSourceWaze"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:textColor="@color/app_text_primary"
                        android:text="@string/source_waze"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/app_border" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSourceMaps"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:textColor="@color/app_text_primary"
                        android:text="@string/source_maps"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/app_border" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editUrlLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_url"
                    app:boxBackgroundColor="@color/app_surface_alt"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:boxStrokeColor="@color/app_primary"
                    app:hintTextColor="@color/app_text_secondary"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textDirection="ltr"
                        android:textSize="14sp"
                        android:textColor="@color/app_text_primary"
                        android:gravity="start" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConvert"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_convert"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    app:cornerRadius="10dp"
                    app:backgroundTint="@color/app_primary" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="@color/app_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_error"
                    android:textColor="@color/app_error"
                    android:textSize="13sp"
                    android:textIsSelectable="true"
                    android:textDirection="ltr"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- מפה מוטמעת - גובה ניתן לשינוי בגרירה, כפתור הרחבה למסך מלא בפינה -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/app_border"
            app:cardBackgroundColor="@color/app_surface">

            <LinearLayout
                android:id="@+id/mapCardContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/embeddedMapContainer"
                    android:layout_width="match_parent"
                    android:layout_height="240dp">

                    <WebView
                        android:id="@+id/mapWebView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExpandMap"
                        style="?attr/materialIconButtonFilledStyle"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="top|start"
                        android:layout_margin="8dp"
                        android:contentDescription="@string/btn_pick_on_map"
                        app:icon="@drawable/ic_expand"
                        app:iconSize="16dp"
                        app:backgroundTint="@color/app_surface"
                        app:iconTint="@color/app_text_primary" />

                </FrameLayout>

                <!-- ידית גרירה לשינוי גובה אזור המפה -->
                <LinearLayout
                    android:id="@+id/mapResizeHandle"
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:gravity="center"
                    android:background="@color/app_surface_alt"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="4dp"
                        android:background="@drawable/bg_resize_grip" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- כרטיס תוצאה - מופיע רק כשיש קואורדינטות -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/app_border"
            app:cardBackgroundColor="@color/app_surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- הקואורדינטה היא האלמנט המוביל - גדולה, מונוספייס, ניתנת להעתקה בהקשה -->
                <LinearLayout
                    android:id="@+id/coordPill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_coord_pill"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/coordCombined"
                        android:textDirection="ltr"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_primary_dark" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/app_icon_muted" />

                </LinearLayout>

                <!-- שורת פעולות - מפות/ניווט עם תווית מותג גנרית (לא לוגו רשמי), העתק -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:id="@+id/btnOpenMaps"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_pin"
                            app:tint="@color/app_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_google_maps"
                            android:textSize="12sp"
                            android:textColor="@color/app_text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnNavigateWaze"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_navigate"
                            app:tint="@color/app_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_waze"
                            android:textSize="12sp"
                            android:textColor="@color/app_text_primary" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/app_border" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_description"
                    app:boxBackgroundColor="@color/app_surface_alt"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:boxStrokeColor="@color/app_primary"
                    app:hintTextColor="@color/app_text_secondary"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/app_text_primary"
                        android:inputType="textCapSentences" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- כניסה אחת לשליחה - פותחת בורר SMS/WhatsApp -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendMessage"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_send_message"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    app:cornerRadius="10dp"
                    app:backgroundTint="@color/app_success"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    </ScrollView>

    <!-- כפתור "כווץ" - מוצג רק כשהמפה מורחבת למסך מלא, חופף את כל הדף -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCollapseMap"
        style="?attr/materialIconButtonFilledStyle"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="top|start"
        android:layout_margin="14dp"
        app:icon="@drawable/ic_collapse"
        app:iconSize="20dp"
        app:backgroundTint="@color/app_surface"
        app:iconTint="@color/app_text_primary"
        android:visibility="gone" />

</FrameLayout>
