<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:layoutDirection="rtl">

        <!-- כותרת + טוגל מצב כהה/בהיר, שורה אחת רגועה -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleTheme"
                style="?attr/materialIconButtonStyle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/ic_theme_toggle"
                app:iconTint="@color/app_text_secondary" />

        </LinearLayout>

        <!-- כרטיס ההמרה הראשי -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/app_border"
            app:cardBackgroundColor="@color/app_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/sourceToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSourceWaze"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/app_text_primary"
                        android:text="@string/source_waze"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/app_border" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSourceMaps"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/app_text_primary"
                        android:text="@string/source_maps"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/app_border" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editUrlLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_url"
                    app:boxBackgroundColor="@color/app_surface_alt"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:hintTextColor="@color/app_text_secondary"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textDirection="ltr"
                        android:textColor="@color/app_text_primary"
                        android:gravity="start" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickOnMap"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/btn_pick_on_map"
                        android:textSize="13sp"
                        android:textColor="@color/app_text_primary"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/app_border"
                        app:icon="@drawable/ic_map"
                        app:iconTint="@color/app_text_secondary"
                        app:iconGravity="textStart" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConvert"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/btn_convert"
                        android:textSize="14sp"
                        app:cornerRadius="10dp"
                        app:backgroundTint="@color/app_primary" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="14dp"
                    android:indeterminateTint="@color/app_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_error"
                    android:textColor="@color/app_error"
                    android:textSize="13sp"
                    android:textIsSelectable="true"
                    android:textDirection="ltr"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- כרטיס תוצאה - מופיע רק כשיש קואורדינטות -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/app_border"
            app:cardBackgroundColor="@color/app_surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- הקואורדינטה היא האלמנט המוביל - גדולה, מונוספייס, ניתנת להעתקה בהקשה -->
                <LinearLayout
                    android:id="@+id/coordPill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_coord_pill"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/coordCombined"
                        android:textDirection="ltr"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_primary_dark" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/app_icon_muted" />

                </LinearLayout>

                <!-- שורת פעולות איקונים - העתק / מפות / נווט -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopy"
                        style="?attr/materialIconButtonFilledTonalStyle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="10dp"
                        app:icon="@drawable/ic_copy"
                        app:iconTint="@color/app_text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenMaps"
                        style="?attr/materialIconButtonFilledTonalStyle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="10dp"
                        app:icon="@drawable/ic_pin"
                        app:iconTint="@color/app_text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNavigateWaze"
                        style="?attr/materialIconButtonFilledTonalStyle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_navigate"
                        app:iconTint="@color/app_text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/app_border" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_description"
                    app:boxBackgroundColor="@color/app_surface_alt"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:hintTextColor="@color/app_text_secondary"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_primary"
                        android:inputType="textCapSentences" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- כניסה אחת לשליחה - פותחת בורר SMS/WhatsApp -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendMessage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/btn_send_message"
                    android:textSize="14sp"
                    app:cornerRadius="10dp"
                    app:backgroundTint="@color/app_success"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    </ScrollView>

    <!-- מסך מפה במסך מלא - מכוסה על כל המסך כשהוא פעיל (visibility=gone כברירת מחדל).
         כל ממשק המשתמש (סרגל כלים, חיפוש כתובת, כפתורי GPS, רמזים) מצויר בתוך ה-HTML/JS
         עצמו (map.html) ולא ב-native, כדי לתמוך בעיצוב המודרני המבוסס Leaflet.Draw. -->
    <FrameLayout
        android:id="@+id/mapFullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#ffffff"
        android:visibility="gone">

        <WebView
            android:id="@+id/mapWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

</FrameLayout>
